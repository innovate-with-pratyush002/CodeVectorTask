generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  category  String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // This composite index matches the API sort order.
  // PostgreSQL can use it to quickly fetch the next page for cursor pagination.
  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "idx_products_created_at_id_desc")

  // This index keeps category filtering fast when the table grows.
  @@index([category], map: "idx_products_category")

  @@map("products")
}
